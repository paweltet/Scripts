trigger:
- none  # run manually

variables:
  terraformWorkingDirectory: 'infra'
  terraformVersion: '1.10.5'

  # Your existing Azure resources
  azResourceGroupName: 'rg-terraform-state'
  azStorageAccountName: 'sttfstateunq001'
  azContainerName: 'tfstate'
  azStateKey: 'your-app.tfstate'

  # Your Azure service connection name in ADO
  serviceConnectionName: 'sc-azure-dev'  # change to your actual connection

stages:
- stage: init_plan_apply
  displayName: 'Test storage backend with plan & apply'
  jobs:
  - job: terraform
    pool:
      vmImage: 'ubuntu-latest'
    steps:
    - checkout: self

    - task: TerraformInstaller@1
      displayName: 'Install Terraform'
      inputs:
        terraformVersion: '$(terraformVersion)'

    - task: AzureCLI@2
      displayName: 'Azure login (service connection)'
      inputs:
        azureSubscription: '$(serviceConnectionName)'
        scriptType: 'bash'
        scriptLocation: 'inlineScript'
        inlineScript: |
          echo "Logged in via service connection."

    # Just write backend config (no secrets)
    - task: Bash@3
      displayName: 'Write backend config'
      inputs:
        targetType: 'inline'
        script: |
          set -euo pipefail
          cd '$(terraformWorkingDirectory)'
          tee backend.tf > /dev/null <<EOF
          terraform {
            backend "azurerm" {
              resource_group_name  = "$(azResourceGroupName)"
              storage_account_name = "$(azStorageAccountName)"
              container_name       = "$(azContainerName)"
              key                  = "$(azStateKey)"
            }
          }
          EOF
          cat backend.tf

    # Init + Plan + Apply (simple test resource)
    - task: Bash@3
      displayName: 'Terraform init, plan, apply'
      inputs:
        targetType: 'inline'
        script: |
          set -euo pipefail
          cd '$(terraformWorkingDirectory)'

          # Write a tiny test resource (e.g., a resource group)
          tee main.tf > /dev/null <<EOF
          resource "azurerm_resource_group" "test" {
            name     = "rg-test-storage-avail"
            location = "westeurope"
          }
          EOF

          terraform init -input=false
          terraform plan -out=tfplan -input=false -no-color
          terraform apply -input=false -no-color -auto-approve=false tfplan
